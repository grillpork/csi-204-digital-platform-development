generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  admin
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  address   String?
  phone     String?
  role      Role     @default(customer)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}
