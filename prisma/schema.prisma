generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  admin
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  address   String?
  phone     String?
  role      Role     @default(customer)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
